{
  "info": {
    "name": "cloudata-live-panel-api",
    "description": "Postman collection generated from the LR Remote Access Flask routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "server_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "session_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "path",
      "value": ".",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"user1\",\n  \"password\": \"pass123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "register"
              ]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"user1\",\n  \"password\": \"pass123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "login"
              ]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "logout"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Files",
      "item": [
        {
          "name": "List files",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/files?path={{path}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "files"
              ],
              "query": [
                {
                  "key": "path",
                  "value": "{{path}}"
                }
              ]
            }
          }
        },
        {
          "name": "Read file",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/read-file?path={{path}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "read-file"
              ],
              "query": [
                {
                  "key": "path",
                  "value": "{{path}}"
                }
              ]
            }
          }
        },
        {
          "name": "Create file",
          "request": {
            "method": "POST",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "path",
                  "value": "{{path}}"
                },
                {
                  "key": "content",
                  "value": "Hello from Postman"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/create-file",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "create-file"
              ]
            }
          }
        },
        {
          "name": "Upload file",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                },
                {
                  "key": "path",
                  "value": "{{path}}/uploaded.txt",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/upload-file",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "upload-file"
              ]
            }
          }
        },
        {
          "name": "Delete file",
          "request": {
            "method": "POST",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "path",
                  "value": "{{path}}/uploaded.txt"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/delete-file",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "delete-file"
              ]
            }
          }
        }
      ]
    },
